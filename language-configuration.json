{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "<", "close": ">" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["<", ">"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(import|service|struct|enum)\\b",
      "end": "^\\s*$"
    }
  }
}
